  fulfillmentCenter String?   @map("fulfillment_center")
  disposition       String?
  reason            String?
  country           String?
  reconciledQty     Int       @default(0) @map("reconciled_qty")
  unreconciledQty   Int       @default(0) @map("unreconciled_qty")
  adjDatetime       DateTime? @map("adj_datetime")
  store             String?
  rowHash           String?   @map("row_hash")
  uploadedAt        DateTime  @default(now()) @map("uploaded_at")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@unique([referenceId, fnsku, adjDate, quantity], name: "inv_adj_dedup")
  @@index([msku])
  @@index([fnsku])
  @@index([asin])
  @@index([referenceId])
  @@index([adjDate])
  @@index([store])
  @@index([rowHash])
  @@map("inventory_adjustments")
