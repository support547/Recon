// =============================================================
// FBA Inventory ERP — Prisma Schema
// Database: PostgreSQL (fresh)
// Generated from: InvenSync HTML audit
// Decisions applied:
//   - FC transfers INCLUDED in reconciliation formula
//   - Multi-store support ON (store column kept everywhere)
//   - RemovalReceipts ALL fields kept (full migration shape)
//   - Soft delete (deletedAt) on all business record models
//   - Every model has id (cuid), createdAt, updatedAt
//   - snake_case table names via @@map
//   - @@index on all FK and commonly filtered fields
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================
// ENUMS
// =============================================================

enum UserRole {
  ADMIN
  VENDOR
  VIEWER
}

enum PermissionModule {
  REPORTS
  RECONCILIATION
  SETTLEMENTS
  PAYMENTS
  DATA_EXPLORER
  USERS
  AUDIT
  SETTINGS
}

enum PermissionLevel {
  NONE
  VIEW
  EDIT
  FULL
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  USER_CREATED
  USER_UPDATED
  USER_ROLE_CHANGED
  USER_SUSPENDED
  USER_REACTIVATED
  USER_DELETED
  USER_PASSWORD_RESET
  PERMISSION_OVERRIDE_SET
  PERMISSION_OVERRIDE_CLEARED
  PROFILE_UPDATED
  PROFILE_PASSWORD_CHANGED
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum ReconType {
  SHIPMENT
  REMOVAL
  RETURN
  FC_TRANSFER
  REIMBURSEMENT
  FBA_BALANCE
  GNR
  REPLACEMENT
  ADJUSTMENT
  OTHER
}

enum AdjType {
  QUANTITY
  FINANCIAL
  STATUS
  OTHER
  RETURN_NEW_MSKU
  LOST
}

enum GradeResellStatus {
  PENDING
  GRADED
  LISTED
  SOLD
  RETURNED
  DISPOSED
}

enum WareHouseStatus {
  PENDING
  RECEIVED
  PROCESSED
  COMPLETE
}

enum RemovalReceiptStatus {
  AWAITING
  PARTIAL
  COMPLETE
  MISSING
  DAMAGED
  REIMBURSED
  NOT_APPLICABLE
}

enum FinalStatus {
  OPEN
  RESOLVED
  CLOSED
}

// =============================================================
// AUTH / USERS
// =============================================================

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  role               UserRole  @default(VIEWER)
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  lastLoginAt        DateTime?
  // Admin-managed profile / contact detail. All optional, filled after creation.
  designation        String?
  mobile             String?
  dateJoined         DateTime? @map("date_joined")
  address            String?
  department         String?
  employeeId         String?   @unique @map("employee_id")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  permissionOverrides UserPermissionOverride[]
  auditLogs           AuditLog[]               @relation("AuditActor")

  @@index([email])
  @@index([role])
  @@map("users")
}

model UserPermissionOverride {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  module    PermissionModule
  level     PermissionLevel
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
  @@map("user_permission_overrides")
}

model AuditLog {
  id          String      @id @default(cuid())
  actorId     String?     @map("actor_id")
  actorEmail  String?     @map("actor_email")
  action      AuditAction
  targetType  String?     @map("target_type")
  targetId    String?     @map("target_id")
  targetEmail String?     @map("target_email")
  summary     String
  metadata    Json?
  ipAddress   String?     @map("ip_address")
  createdAt   DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================
// UPLOAD TRACKING
// =============================================================

model UploadedFile {
  id               String    @id @default(cuid())
  reportType       String
  filename         String
  rowCount         Int       @default(0)
  rowsSkipped      Int       @default(0)
  isLocked         Boolean   @default(false)
  store            String?
  dataTargetTable  String?   @map("data_target_table") @db.VarChar(64)
  reportLatestDate DateTime? @map("report_latest_date") @db.Date
  uploadedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([reportType])
  @@index([uploadedAt])
  @@index([store])
  @@map("uploaded_files")
}

// =============================================================
// CORE UPLOADED FACT TABLES
// =============================================================

model ShippedToFba {
  id         String    @id @default(cuid())
  msku       String
  title      String?
  asin       String?
  fnsku      String?
  shipDate   DateTime?
  quantity   Int       @default(0)
  shipmentId String?
  store      String?

  publisherName             String?   @map("publisher_name")
  supplierName              String?   @map("supplier_name")
  deliveryLocation          String?   @map("delivery_location")
  purchaseId                String?   @map("purchase_id")
  finalNetPriceUsd          Decimal?  @map("final_net_price_usd") @db.Decimal(12, 4)
  commissionUsd             Decimal?  @map("commission_usd") @db.Decimal(12, 4)
  supplierShippingUsd       Decimal?  @map("supplier_shipping_usd") @db.Decimal(12, 4)
  warehousePrepUsd          Decimal?  @map("warehouse_prep_usd") @db.Decimal(12, 4)
  inventoryPlaceInboundUsd  Decimal?  @map("inventory_place_inbound_usd") @db.Decimal(12, 4)
  expertChargesUsd          Decimal?  @map("expert_charges_usd") @db.Decimal(12, 4)
  otherChargesUsd           Decimal?  @map("other_charges_usd") @db.Decimal(12, 4)
  perBookCostUsd            Decimal?  @map("per_book_cost_usd") @db.Decimal(12, 4)
  finalTotalPurchaseCostUsd Decimal?  @map("final_total_purchase_cost_usd") @db.Decimal(12, 4)
  costUpdatedAt             DateTime? @map("cost_updated_at")

  uploadedAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@unique([shipmentId, msku, fnsku])
  @@index([msku])
  @@index([fnsku])
  @@index([asin])
  @@index([shipmentId])
  @@index([store])
  @@index([shipDate])
  @@map("shipped_to_fba")
}

