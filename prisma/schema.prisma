// =============================================================
// FBA Inventory ERP — Prisma Schema
// Database: PostgreSQL (fresh)
// Generated from: InvenSync HTML audit
// Decisions applied:
//   - FC transfers INCLUDED in reconciliation formula
//   - Multi-store support ON (store column kept everywhere)
//   - RemovalReceipts ALL fields kept (full migration shape)
//   - Soft delete (deletedAt) on all business record models
//   - Every model has id (cuid), createdAt, updatedAt
//   - snake_case table names via @@map
//   - @@index on all FK and commonly filtered fields
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================
// ENUMS
// =============================================================

enum UserRole {
  ADMIN
  VENDOR
  VIEWER
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum ReconType {
  SHIPMENT
  REMOVAL
  RETURN
  FC_TRANSFER
  REIMBURSEMENT
  FBA_BALANCE
  GNR
  REPLACEMENT
  OTHER
}

enum AdjType {
  QUANTITY
  FINANCIAL
  STATUS
  OTHER
}

enum GradeResellStatus {
  PENDING
  GRADED
  LISTED
  SOLD
  RETURNED
  DISPOSED
}

enum WareHouseStatus {
  PENDING
  RECEIVED
  PROCESSED
  COMPLETE
}

enum RemovalReceiptStatus {
  AWAITING
  PARTIAL
  COMPLETE
  MISSING
  DAMAGED
  REIMBURSED
  NOT_APPLICABLE
}

enum FinalStatus {
  OPEN
  RESOLVED
  CLOSED
}

// =============================================================
// AUTH / USERS
// =============================================================

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(VIEWER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([email])
  @@index([role])
  @@map("users")
}

// =============================================================
// UPLOAD TRACKING
// =============================================================

model UploadedFile {
  id               String    @id @default(cuid())
  reportType       String
  filename         String
  rowCount         Int       @default(0)
  rowsSkipped      Int       @default(0)
  isLocked         Boolean   @default(false)
  store            String?
  dataTargetTable  String?   @map("data_target_table") @db.VarChar(64)
  reportLatestDate DateTime? @map("report_latest_date") @db.Date
  uploadedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([reportType])
  @@index([uploadedAt])
  @@index([store])
  @@map("uploaded_files")
}

// =============================================================
// CORE UPLOADED FACT TABLES
// =============================================================

model ShippedToFba {
  id         String    @id @default(cuid())
  msku       String
  title      String?
  asin       String?
  fnsku      String?
  shipDate   DateTime?
  quantity   Int       @default(0)
  shipmentId String?
  store      String?

  publisherName             String?   @map("publisher_name")
  supplierName              String?   @map("supplier_name")
  deliveryLocation          String?   @map("delivery_location")
  purchaseId                String?   @map("purchase_id")
  finalNetPriceUsd          Decimal?  @map("final_net_price_usd") @db.Decimal(12, 4)
  commissionUsd             Decimal?  @map("commission_usd") @db.Decimal(12, 4)
  supplierShippingUsd       Decimal?  @map("supplier_shipping_usd") @db.Decimal(12, 4)
  warehousePrepUsd          Decimal?  @map("warehouse_prep_usd") @db.Decimal(12, 4)
  inventoryPlaceInboundUsd  Decimal?  @map("inventory_place_inbound_usd") @db.Decimal(12, 4)
  expertChargesUsd          Decimal?  @map("expert_charges_usd") @db.Decimal(12, 4)
  otherChargesUsd           Decimal?  @map("other_charges_usd") @db.Decimal(12, 4)
  perBookCostUsd            Decimal?  @map("per_book_cost_usd") @db.Decimal(12, 4)
  finalTotalPurchaseCostUsd Decimal?  @map("final_total_purchase_cost_usd") @db.Decimal(12, 4)
  costUpdatedAt             DateTime? @map("cost_updated_at")

  uploadedAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@unique([shipmentId, msku, fnsku])
  @@index([msku])
  @@index([fnsku])
  @@index([asin])
  @@index([shipmentId])
  @@index([store])
  @@index([shipDate])
  @@map("shipped_to_fba")
}

model SalesData {
  id             String    @id @default(cuid())
  msku           String?
  fnsku          String?
  asin           String?
  quantity       Int       @default(0)
  saleDate       DateTime?
  orderId        String?
  currency       String?
  productAmount  Decimal?  @db.Decimal(12, 2)
  shippingAmount Decimal?  @db.Decimal(12, 2)
  giftAmount     Decimal?  @db.Decimal(12, 2)
  fc             String?
  shipCity       String?
  shipState      String?
  shipPostalCode String?
  store          String?
  uploadedAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@unique([orderId, saleDate])
  @@index([msku])
  @@index([fnsku])
  @@index([asin])
  @@index([orderId])
  @@index([saleDate])
  @@index([store])
  @@map("sales_data")
}

model FbaReceipt {
  id                String    @id @default(cuid())
  msku              String?
  title             String?
  asin              String?
  fnsku             String?
  quantity          Int       @default(0)
  receiptDate       DateTime?
  shipmentId        String?
  eventType         String?
  fulfillmentCenter String?
  disposition       String?
  reason            String?
  country           String?
  reconciledQty     Int       @default(0)
  unreconciledQty   Int       @default(0)
  receiptDatetime   DateTime?
  store             String?
  uploadedAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@unique([fnsku, receiptDate, shipmentId])
  @@index([msku])
  @@index([fnsku])
  @@index([shipmentId])
  @@index([store])
  @@index([receiptDate])
  @@map("fba_receipts")
}

model CustomerReturn {
  id                  String    @id @default(cuid())
  msku                String?
  asin                String?
  fnsku               String?
  title               String?
  quantity            Int       @default(0)
  disposition         String?
  detailedDisposition String?
  reason              String?
  status              String?
  returnDate          DateTime?
  orderId             String?
  fulfillmentCenter   String?
  licensePlateNumber  String?
  customerComments    String?
  store               String?
  uploadedAt          DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  @@unique([orderId, fnsku, returnDate])
  @@index([msku])
  @@index([fnsku])
  @@index([asin])
  @@index([orderId])
  @@index([returnDate])
  @@index([store])
  @@map("customer_returns")
}

model Reimbursement {
  id                String    @id @default(cuid())
  msku              String?
  fnsku             String?
  asin              String?
  title             String?
  reason            String?
  quantity          Int       @default(0)
  amount            Decimal?  @db.Decimal(12, 2)
  reimbursementId   String?
  approvalDate      DateTime?
  caseId            String?
  amazonOrderId     String?
  conditionVal      String?
  currency          String?
  amountPerUnit     Decimal?  @db.Decimal(12, 2)
  qtyCash           Int       @default(0)
  qtyInventory      Int       @default(0)
  originalReimbId   String?
  originalReimbType String?
