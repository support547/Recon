model GradeResellItem {
  id            String            @id @default(cuid())
  source        String?
  sourceRef     String?
  msku          String
  fnsku         String?
  asin          String?
  title         String?
  quantity      Int               @default(0)
  grade         String?
  resellPrice   Decimal?          @db.Decimal(12, 2)
  channel       String?
  status        GradeResellStatus @default(PENDING)
  notes         String?
  gradedBy      String?
  gradedDate    DateTime?
  soldDate      DateTime?
  soldPrice     Decimal?          @db.Decimal(12, 2)
  // GNR extended fields
  orderId       String?
  lpn           String?
  usedMsku      String?
  usedFnsku     String?
  usedCondition String?
  unitStatus    String?
  store         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  // PostgreSQL allows multiple NULLs through @@unique. For strict dedup,
  // add a partial unique index in migration SQL:
  //   CREATE UNIQUE INDEX grade_resell_used_key
  //     ON grade_resell_items(used_msku, used_fnsku)
  //     WHERE used_msku IS NOT NULL AND used_fnsku IS NOT NULL;
  @@unique([usedMsku, usedFnsku])
  @@index([msku])
  @@index([fnsku])
  @@index([status])
  @@index([store])
  @@map("grade_resell_items")
}

