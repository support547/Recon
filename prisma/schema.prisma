// =============================================================
// REMOVAL OPERATIONS
// =============================================================

model RemovalShipment {
  id               String    @id @default(cuid())
  orderId          String?
  requestDate      DateTime?
  shipmentDate     DateTime?
  msku             String?
  fnsku            String?
  disposition      String?
  shippedQty       Int       @default(0)
  carrier          String?
  trackingNumber   String?
  removalOrderType String?
  store            String?
  rowHash          String?
  uploadedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@index([orderId])
  @@index([msku])
  @@index([fnsku])
  @@index([store])
  @@index([rowHash])
  @@map("removal_shipments")
}

model RemovalReceipt {
  id                String               @id @default(cuid())
  // Core receipt fields
  orderId           String?
  fnsku             String?
  msku              String?
  trackingNumber    String?
  carrier           String?
  expectedQty       Int                  @default(0)
  receivedDate      DateTime?
  receivedQty       Int                  @default(0)
  sellableQty       Int                  @default(0)
  unsellableQty     Int                  @default(0)
  conditionReceived String?
  missingQty        Int                  @default(0) // computed: expectedQty - receivedQty
  notes             String?
  receivedBy        String?
  status            RemovalReceiptStatus @default(AWAITING)
  warehouseComment  String?
  transferTo        String?
  whStatus          WareHouseStatus      @default(PENDING)
  // Extended seller / billing fields
  sellerStatus      String?
  sellerComments    String?
  warehouseBilled   Boolean              @default(false)
  billedDate        DateTime?
  billedAmount      Decimal?             @db.Decimal(12, 2)
  wrongItemReceived Boolean              @default(false)
  wrongItemNotes    String?
  reimbQty          Int                  @default(0)
  reimbAmount       Decimal?             @db.Decimal(12, 2)
  postAction        String?
  actionRemarks     String?
  actionDate        DateTime?
  finalStatus       FinalStatus          @default(OPEN)
  // Case linkage
  caseId            String?
  caseType          String?
  caseRaisedAt      DateTime?
  caseTrackerId     String?
  caseRemark        String?              @map("case_remark")
  store             String?
  // Extended fields (Task L)
  invoiceNumber     String?              @map("invoice_number")
  reshippedQty      Int                  @default(0) @map("reshipped_qty")
  itemTitle         String?              @map("item_title")
  binLocation       String?              @map("bin_location")
  lpnNumber            String?           @map("lpn_number")
  bolAttachmentCount   Int               @default(0) @map("bol_attachment_count")
  frontPhotoCount      Int               @default(0) @map("front_photo_count")
  backPhotoCount       Int               @default(0) @map("back_photo_count")
  packingListCount     Int               @default(0) @map("packing_list_count")
  attachmentUrls    Json?                @map("attachment_urls")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?

  @@unique([orderId, fnsku, trackingNumber, receivedDate])
  @@index([orderId])
  @@index([fnsku])
  @@index([msku])
  @@index([trackingNumber])
  @@index([status])
  @@index([store])
  @@map("removal_receipts")
}

