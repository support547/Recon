  settlementId             String?   @map("settlement_id")
  settlementStartDate      DateTime? @map("settlement_start_date")
  settlementEndDate        DateTime? @map("settlement_end_date")
  depositDate              DateTime? @map("deposit_date")
  totalAmount              Decimal?  @map("total_amount") @db.Decimal(14, 4)
  currency                 String?
  transactionType          String?   @map("transaction_type")
  orderId                  String?   @map("order_id")
  merchantOrderId          String?   @map("merchant_order_id")
  adjustmentId             String?   @map("adjustment_id")
  shipmentId               String?   @map("shipment_id")
  marketplaceName          String?   @map("marketplace_name")
  amountType               String?   @map("amount_type")
  amountDescription        String?   @map("amount_description")
  amount                   Decimal?  @db.Decimal(14, 4)
  fulfillmentId            String?   @map("fulfillment_id")
  postedDate               DateTime? @map("posted_date")
  postedDateTime           DateTime? @map("posted_date_time")
  orderItemCode            String?   @map("order_item_code")
  merchantOrderItemId      String?   @map("merchant_order_item_id")
  merchantAdjustmentItemId String?   @map("merchant_adjustment_item_id")
  sku                      String?
  quantityPurchased        Int?      @map("quantity_purchased")
  promotionId              String?   @map("promotion_id")
  store                    String?
  accountType              String?   @map("account_type")
  uploadedAt               DateTime  @default(now()) @map("uploaded_at")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  @@index([settlementId])
  @@index([transactionType])
  @@index([orderId])
  @@index([sku])
  @@index([accountType])
  @@index([settlementId, accountType, store])
  @@index([postedDate])
  @@index([store])
  @@map("settlement_report")
}

model PaymentRepository {
  id                         String    @id @default(cuid())
  postedDatetime             String?
  settlementId               String?
  lineType                   String?
  orderId                    String?
  sku                        String?
  description                String?
  quantity                   Int       @default(0)
  marketplace                String?
  accountType                String?
  fulfillmentId              String?
  taxCollectionModel         String?
  productSales               Decimal?  @db.Decimal(12, 2)
  productSalesTax            Decimal?  @db.Decimal(12, 2)
  shippingCredits            Decimal?  @db.Decimal(12, 2)
  shippingCreditsTax         Decimal?  @db.Decimal(12, 2)
  giftWrapCredits            Decimal?  @db.Decimal(12, 2)
  giftWrapCreditsTax         Decimal?  @db.Decimal(12, 2)
  regulatoryFee              Decimal?  @db.Decimal(12, 2)
  taxOnRegulatoryFee         Decimal?  @db.Decimal(12, 2)
  promotionalRebates         Decimal?  @db.Decimal(12, 2)
  promotionalRebatesTax      Decimal?  @db.Decimal(12, 2)
  marketplaceWithheldTax     Decimal?  @db.Decimal(12, 2)
  sellingFees                Decimal?  @db.Decimal(12, 2)
  fbaFees                    Decimal?  @db.Decimal(12, 2)
  otherTransactionFees       Decimal?  @db.Decimal(12, 2)
  other                      Decimal?  @db.Decimal(12, 2)
  total                      Decimal?  @db.Decimal(12, 2)
  transactionStatus          String?
  transactionReleaseDatetime String?
  store                      String?
  rowHash                    String?
  uploadedAt                 DateTime  @default(now())
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  deletedAt                  DateTime?

  @@index([orderId])
  @@index([sku])
  @@index([settlementId])
  @@index([store])
  @@index([rowHash])
  @@map("payment_repository")
}

// =============================================================
// OPERATIONAL — CASES & ADJUSTMENTS
// =============================================================

model CaseTracker {
  id             String     @id @default(cuid())
  // Identity
  msku           String?
  asin           String?
  fnsku          String?
  title          String?
  // Recon type and references
  reconType      ReconType
  shipmentId     String?
  orderId        String?
  referenceId    String?
  reimbursementId String?
  // Case details
  caseReason     String?
  unitsClaimed   Int        @default(0)
  unitsApproved  Int        @default(0)
  amountClaimed  Decimal?   @db.Decimal(12, 2)
  amountApproved Decimal?   @db.Decimal(12, 2)
  currency       String?    @default("USD")
  // Workflow
  status         CaseStatus @default(OPEN)
  issueDate      DateTime?
  raisedDate     DateTime?
  resolvedDate   DateTime?
  notes          String?
  store          String?
  // External Amazon case page URL + uploaded PDF attachment path
  caseUrl        String?
  attachmentUrl  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  manualAdjustments ManualAdjustment[]

  // For dedup, add a partial unique index in migration SQL:
  //   CREATE UNIQUE INDEX case_tracker_dedup
  //     ON case_tracker(msku, recon_type, shipment_id)
  //     WHERE deleted_at IS NULL AND shipment_id IS NOT NULL;
  @@index([msku])
  @@index([fnsku])
  @@index([asin])
  @@index([reconType])
  @@index([status])
  @@index([shipmentId])
  @@index([orderId])
  @@index([store])
  @@map("case_tracker")
}

model ManualAdjustment {
  id          String       @id @default(cuid())
  // Identity
  msku        String?
  asin        String?
  fnsku       String?
  title       String?
  // Recon type and references
  reconType   ReconType
  shipmentId  String?
  orderId     String?
  referenceId String?
  // Adjustment details
  adjType     AdjType      @default(QUANTITY)
  qtyBefore   Int          @default(0)
  qtyAdjusted Int          @default(0)
  qtyAfter    Int          @default(0)
  amount      Decimal?     @db.Decimal(12, 2)
  reason      String?
  verifiedBy  String?
  sourceDoc   String?
  notes       String?
  adjDate     DateTime?
  store       String?
  receivedAsFnsku String?  @map("received_as_fnsku")
  // Original MSKU — for RETURN_NEW_MSKU: the MSKU the unit was originally
  // listed/sold under, before it returned under a new MSKU.
  originalMsku String?  @map("original_msku")
  // Optional case link
  caseId      String?
  case        CaseTracker? @relation(fields: [caseId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@index([msku])
  @@index([fnsku])
  @@index([reconType])
  @@index([caseId])
  @@index([store])
  @@map("manual_adjustments")
}

// =============================================================
// RECONCILIATION SUMMARY VIEW (materialised as a table)
// The original is a SQL VIEW — we replicate as a refresh-able
// snapshot table so Next.js can query it via Prisma easily.
// FC transfers are INCLUDED per your decision.
// =============================================================

model ReconciliationSummary {
  id               String   @id @default(cuid())
  msku             String
  fnsku            String?
  asin             String?
  title            String?
  store            String?
  // Quantity components
  shippedQty       Int      @default(0)
  receivedQty      Int      @default(0)
  soldQty          Int      @default(0)
  returnQty        Int      @default(0)
  reimbQty         Int      @default(0)
  removalQty       Int      @default(0)
  fcTransferQty    Int      @default(0) // ← INCLUDED (your decision)
  fbaEndingBalance Int      @default(0)
  // Computed
  expectedQty      Int      @default(0) // shipped + received + returns + reimb + fcTransfer − sold − removals
  actualQty        Int      @default(0)
  variance         Int      @default(0) // expectedQty − actualQty
  // Status
  status           String   @default("pending") // matched / pending / mismatch
  lastRefreshedAt  DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([msku, store])
  @@index([msku])
  @@index([fnsku])
  @@index([status])
  @@index([store])
  @@map("reconciliation_summary")
}

model InboundShipment {
  id               String    @id @default(cuid())
  shipmentId       String                                // Amazon Shipment ID, e.g. FBA197CMP0XH
  manualProcFee    Decimal?  @db.Decimal(12, 2) @map("manual_proc_fee")    // FBA manual processing fee
  placementFee     Decimal?  @db.Decimal(12, 2) @map("placement_fee")      // Total inbound placement service fees
  partneredCarrier Decimal?  @db.Decimal(12, 2) @map("partnered_carrier")  // Amazon partnered carrier cost

  // Snapshot fields copied from ShipmentStatus at upsert / Shipping Queue upload.
  shipmentName     String?
  createdDate      DateTime?
  lastUpdated      DateTime?
  unitsLocated     Int?
  shipmentStatus   String?
  shipTo           String?

  // Actuals pulled from SettlementReport (sums per inbound fee description).
  settledTransport Decimal? @db.Decimal(12, 2)
  settledPlacement Decimal? @db.Decimal(12, 2)
  settlementIds    String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@index([shipmentId])
  @@map("inbound_shipments")
}

